# Copy this file to .env and fill in your own values.

# ── Supabase (required) ─────────────────────────────────────────────────────
# Project Settings → Database → Connection string → URI (Session pooler)
DATABASE_URL=postgresql://postgres.xxxxx:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require

# ── Auth for LAN / remote / mobile clients ──────────────────────────────────
VIEWER_AUTH_TOKEN=Test123
CORS_ORIGINS=capacitor://localhost,https://localhost

# ── MEGA import (your own MEGA.nz account) ──────────────────────────────────
# Used by the "Import from folder" tool: it logs into this account, uploads
# whatever folder you pick into MEGA_ROOT_FOLDER/<folder name>, and serves
# the files back out through the backend at /api/mega/stream/...
MEGA_EMAIL=
MEGA_PASSWORD=
MEGA_ROOT_FOLDER=ViewerUploads

# Optional: only set this if the backend is behind a proxy/host where
# request.host_url doesn't match the URL your frontend actually uses to
# reach it (e.g. some Render setups). Leave blank otherwise.
MEGA_PUBLIC_BASE_URL=
