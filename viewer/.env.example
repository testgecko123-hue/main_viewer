# ── Supabase (required) ──────────────────────────────────────────────────────
# Project Settings → Database → Connection string → URI
# For the Flask backend, use "Session pooler" (port 6543) or "Direct" (port 5432).
# Append ?sslmode=require if not already present.
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require

# API auth token — required for LAN/mobile/Render clients (not localhost proxy dev).
VIEWER_AUTH_TOKEN=change-me-to-a-long-secret

# Extra CORS origins (comma-separated). LAN private IPs are allowed automatically.
# CORS_ORIGINS=https://your-viewer-api.onrender.com

# ── Frontend (Android / production web) ────────────────────────────────────
# Copy these to frontend/.env (not root .env). Leave empty for PC-only dev (Vite proxy).
# VITE_API_URL=https://your-viewer-api.onrender.com
# VITE_AUTH_TOKEN=change-me-to-a-long-secret

# ── Supabase API keys (optional — for future client-side use) ───────────────
# Project Settings → API
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
